# PostgreSQL
POSTGRES_DB=radar_db
POSTGRES_USER=radar_user
POSTGRES_PASSWORD=radar_password

# Backend
DATABASE_URL=postgresql://radar_user:radar_password@postgres:5432/radar_db
SEED_ON_STARTUP=true

# CoinMarketCap (required for live 24h %, price, volume, market cap)
# Get a free key at: https://coinmarketcap.com/api/
CMC_API_KEY=your_coinmarketcap_api_key_here
CMC_LISTINGS_LIMIT=50
# Min 60 — one listings/latest call per sync (~1 CMC credit). 60s ≈ 1440 credits/day.
CMC_SYNC_INTERVAL_SECONDS=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
